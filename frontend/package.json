{
  "name": "frontend",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:platform-admin": "pnpm --filter platform-admin dev",
    "dev:business-admin": "pnpm --filter business-admin dev",
    "dev:public-menu": "pnpm --filter public-menu dev",
    "dev:staff-order": "pnpm --filter staff-order dev",
    "dev:customer-display": "pnpm --filter customer-display dev",
    "dev:kitchen-display": "pnpm --filter kitchen-display dev",
    "dev:terminal": "pnpm --filter terminal dev",
    "build": "turbo build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "turbo typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "e2e": "playwright test --pass-with-no-tests",
    "format": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.6.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
