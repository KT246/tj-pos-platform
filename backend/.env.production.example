NODE_ENV=production

# Copy the Session pooler URL from Supabase Connect. It is suitable for a persistent API on an IPv4 server.
DATABASE_URL=postgresql://postgres.rpgdiinssyhabilkwfsk:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_SSL=require
DATABASE_MAX_CONNECTIONS=5

# Public Tunnel hostname used when the API returns uploaded image URLs.
PUBLIC_BASE_URL=https://api.example.com

# Comma-separated frontend domains allowed to call the API.
CORS_ORIGIN=https://your-worker.workers.dev

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# First administrator written to an empty Supabase database at first startup.
INITIAL_BUSINESS_SLUG=tj-cafe-vientiane
INITIAL_BUSINESS_NAME=TJ Cafe Vientiane
INITIAL_ADMIN_NAME=Store Owner
INITIAL_ADMIN_USERNAME=owner
INITIAL_ADMIN_EMAIL=owner@example.com
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
